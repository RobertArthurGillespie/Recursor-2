@page "/pages-aichat"
@using System.Text.Json
@using System.Text
@using Microsoft.AspNetCore.Components.Authorization
@inject HttpClient Http


<div class="chat-container">
    <div class="chat-header">
        <h3>NCAT AI Assistant</h3>
    </div>

    <div class="chat-window" id="chatWindow">
        @foreach (var message in ChatHistory)
        {
                <div class="message-bubble @(message.IsUser ? "user" : "assistant")">
                    <div class="content">
                    @message.Text
                    </div>
                @if (!string.IsNullOrEmpty(message.Context) && !message.IsUser)
                {
                            <details class="context-debug">
                                <summary>View Source Context</summary>
                                <pre>@message.Context</pre>
                            </details>
                }
                </div>
        }
        @if (IsLoading)
        {
                <div class="message-bubble assistant loading">
                    <span class="dot"></span><span class="dot"></span><span class="dot"></span>
                </div>
        }
    </div>

    <div class="chat-input-area">
        <input type="text" 
               @bind="UserMessage" 
               @bind:event="oninput"
               @onkeyup="HandleKeyPress"
               placeholder="Ask a question about your documents..." 
               disabled="@IsLoading" />
        <button @onclick="SendMessage" disabled="@(string.IsNullOrWhiteSpace(UserMessage) || IsLoading)">
            Send
        </button>
    </div>
</div>

@code {
    private string UserMessage { get; set; } = "";
    private bool IsLoading { get; set; } = false;
    private List<ChatMessage> ChatHistory { get; set; } = new();

    [Inject] NavigationManager Nav { get; set; }

    private async Task HandleKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await SendMessage();
        }
    }

    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(UserMessage)) return;

        var userRequest = UserMessage;
        UserMessage = ""; // Clear input

        // Add user message to UI
        ChatHistory.Add(new ChatMessage { Text = userRequest, IsUser = true });
        IsLoading = true;

        try
        {
            var request = new { Message = userRequest };
            var apiUrl = "https://testinterface-gce2f9gtaqdbcva8.eastus-01.azurewebsites.net/Chat/AIChat";

            var response = await Http.PostAsJsonAsync(apiUrl, request);

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<ChatResponse>();
                ChatHistory.Add(new ChatMessage
                    {
                        Text = result?.Answer ?? "Sorry, I received an empty response.",
                        Context = result?.Context,
                        IsUser = false
                    });
            }
            else
            {
                ChatHistory.Add(new ChatMessage { Text = "Error: Could not reach the AI service.", IsUser = false });
            }
        }
        catch (Exception ex)
        {
            ChatHistory.Add(new ChatMessage { Text = $"Fatal Error: {ex.Message}", IsUser = false });
        }
        finally
        {
            IsLoading = false;
        }
    }

    public class ChatMessage
    {
        public string Text { get; set; }
        public string Context { get; set; }
        public bool IsUser { get; set; }
    }

    public class ChatResponse
    {
        public string Answer { get; set; }
        public string Context { get; set; }
    }

    private void RedirectToLogin()
    {
        Nav.NavigateTo("/auth-login"); // Or your specific login route
    }
}

<style>
    .chat-container { max-width: 800px; margin: 2rem auto; border: 1px solid #ddd; border-radius: 8px; display: flex; flex-direction: column; height: 70vh; background: white; }
    .chat-header { padding: 1rem; border-bottom: 1px solid #ddd; background: #f8f9fa; border-radius: 8px 8px 0 0; }
    .chat-window { flex: 1; overflow-y: auto; padding: 1rem; display: flex; flex-direction: column; gap: 1rem; background: #fdfdfd; }
    .message-bubble { max-width: 80%; padding: 0.8rem; border-radius: 12px; font-size: 0.95rem; line-height: 1.4; }
    .message-bubble.user { align-self: flex-end; background: #007bff; color: white; border-bottom-right-radius: 2px; }
    .message-bubble.assistant { align-self: flex-start; background: #e9ecef; color: #333; border-bottom-left-radius: 2px; }
    .chat-input-area { padding: 1rem; border-top: 1px solid #ddd; display: flex; gap: 0.5rem; }
    .chat-input-area input { flex: 1; padding: 0.6rem; border: 1px solid #ccc; border-radius: 4px; }
    .chat-input-area button { padding: 0.6rem 1.2rem; background: #007bff; color: white; border: none; border-radius: 4px; cursor: pointer; }
    .chat-input-area button:disabled { background: #ccc; }
    .context-debug { font-size: 0.75rem; margin-top: 0.5rem; color: #666; background: rgba(0,0,0,0.05); padding: 5px; border-radius: 4px; }
    .loading .dot { display: inline-block; width: 6px; height: 6px; border-radius: 50%; background: #999; margin-right: 3px; animation: wave 1.3s linear infinite; }
    .loading .dot:nth-child(2) { animation-delay: -1.1s; }
    .loading .dot:nth-child(3) { animation-delay: -0.9s; }
    @@keyframes wave { 0%, 60%, 100% { transform: initial; } 30% { transform: translateY(-5px); } }
</style>